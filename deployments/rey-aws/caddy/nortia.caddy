nortia-api.15-135-178-84.sslip.io {
	encode gzip

	@health path /health
	handle @health {
		header Content-Type application/json
		respond `{"ok":true,"service":"nortia-backend","network":"solana-devnet"}` 200
	}

	handle_path /committee/1/* {
		reverse_proxy 127.0.0.1:4101
	}

	handle_path /committee/2/* {
		reverse_proxy 127.0.0.1:4102
	}

	handle_path /committee/3/* {
		reverse_proxy 127.0.0.1:4103
	}

	handle_path /prover/* {
		reverse_proxy 127.0.0.1:4200
	}

	respond 404
}
